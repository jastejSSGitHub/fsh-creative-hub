# Supabase — dedicated project ref: rnyeonvbnrwephpviyzu
NEXT_PUBLIC_SUPABASE_URL=https://rnyeonvbnrwephpviyzu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Used for magic-link + OAuth redirect URLs (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3010

# Local only — enables "Skip login" on /login (never set on Vercel production)
DEV_AUTH_BYPASS=true

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Playwright E2E (local + CI — never set E2E_TEST_SECRET on Vercel production)
E2E_TEST_SECRET=local-e2e-secret
E2E_TEST_PASSWORD=e2e-test-password-local

# GitHub Actions: add the same Supabase + E2E values as repository secrets
# so the e2e job in .github/workflows/ci.yml can run smoke tests on every PR.
